{
  "name": "trace-visualizer",
  "displayName": "Trace Visualizer",
  "publisher": "trongnhan",
  "description": "Visualizes function call graphs from JSON data.",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/trongnhan/trace-visualizer"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "trace-visualizer.showGraph",
        "title": "Trace Visualizer: Show Graph"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "16.x",
    "typescript": "^4.9.5"
  }
}
